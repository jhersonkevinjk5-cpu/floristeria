@model IEnumerable<WebApplicationfloristeria.Models.Categoria>

@{
    ViewBag.Title = "Listado de Categorías";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Listado de Categorías</h2>
        <a href="@Url.Action("Create", "Categoria")" class="btn btn-primary">
            <i class="glyphicon glyphicon-plus"></i> Nueva Categoría
        </a>
    </div>

    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Código</th>
                <th>Nombre de Categoría</th>
                <th>Descripción</th>
                <th>Estado</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.IdCategoria</td>
                    <td>@item.NombreCategoria</td>
                    <td>@item.Descripcion</td>
                    <td>
                        @if (item.Estado)
                        {
                            <span class="label label-success">Activo</span>
                        }
                        else
                        {
                            <span class="label label-danger">Inactivo</span>
                        }
                    </td>
                    <td class="text-center">
                        <a href="@Url.Action("Edit", "Categoria", new { id = item.IdCategoria })" class="btn btn-warning btn-sm">
                            <i class="glyphicon glyphicon-pencil"></i> Editar
                        </a>
                        <a href="@Url.Action("Delete", "Categoria", new { id = item.IdCategoria })" class="btn btn-danger btn-sm">
                            <i class="glyphicon glyphicon-trash"></i> Eliminar
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>