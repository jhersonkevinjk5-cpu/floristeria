@{
    ViewBag.Title = "Home Page";
}
<style>
    .card {
        transition: .3s ease;
        border-radius: 15px;
    }

        .card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,.15);
        }
</style>
<main>

    <!-- HERO PRINCIPAL -->
    <section class="row text-center py-5" aria-labelledby="floristeriaTitle"
             style="background: linear-gradient(rgba(0,0,0,.4), rgba(0,0,0,.4)), url('/Content/img/fondo-flores.jpg');
                    background-size: cover;
                    background-position: center;
                    color: white;
                    border-radius: 15px;">

        <h1 id="floristeriaTitle" class="display-4 fw-bold">
            Bienvenido a Pétalos y Aromas <img src="~/Contenido/Multimedia/IMG/logo.png" width="70" />
        </h1>

        <p class="lead mt-3">
            Encuentra arreglos florales únicos para cada ocasión especial.
            Diseñamos emociones a través de cada flor.
        </p>

        <p class="mt-4">
            <a href="/Catalogo" class="btn btn-light btn-lg">
                Ver Catálogo →
            </a>
        </p>
    </section>


    <!-- SECCIONES -->
    <div class="row mt-5 g-4">

        <!-- PRODUCTOS -->
        <section class="col-md-4 text-center">

            <div class="card shadow-lg h-100 border-0">

                <div class="card-body">

                    <div style="font-size:50px;">💐</div>

                    <h2 class="mt-3">Nuestros Productos</h2>

                    <p>
                        Explora una gran variedad de ramos, arreglos florales,
                        cajas premium y detalles personalizados.
                    </p>

                    <a class="btn btn-outline-success" href="/Productos">
                        Explorar →
                    </a>

                </div>

            </div>

        </section>


        <!-- PEDIDOS -->
        <section class="col-md-4 text-center">

            <div class="card shadow-lg h-100 border-0">

                <div class="card-body">

                    <div style="font-size:50px;">🛒</div>

                    <h2 class="mt-3">Realiza tu Pedido</h2>

                    <p>
                        Compra de manera rápida y segura.
                        Agrega tus flores favoritas al carrito y finaliza tu pedido.
                    </p>

                    <a class="btn btn-outline-success" href="/Carrito">
                        Comprar →
                    </a>

                </div>

            </div>

        </section>


        <!-- ADMINISTRACIÓN -->
        <section class="col-md-4 text-center">

            <div class="card shadow-lg h-100 border-0">

                <div class="card-body">

                    <div style="font-size:50px;">📊</div>

                    <h2 class="mt-3">Gestión y Reportes</h2>

                    <p>
                        Administra inventario, clientes, pedidos y genera
                        reportes PDF para un mejor control del negocio.
                    </p>

                    <a class="btn btn-outline-success" href="/Dashboard">
                        Ir al Panel →
                    </a>

                </div>

            </div>

        </section>

    </div>


    <!-- FRASE FINAL -->
    <section class="text-center mt-5 py-4">

        <h3>
            "Cada flor cuenta una historia, nosotros te ayudamos a entregarla." 🌷
        </h3>

    </section>

</main>