@model IEnumerable<WebApplicationfloristeria.Models.Cliente>

@{
    ViewBag.Title = "Listado de Clientes";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Listado de Clientes</h2>
        <a href="@Url.Action("Create", "Cliente")" class="btn btn-primary">
            <i class="glyphicon glyphicon-plus"></i> Registrar Cliente
        </a>
    </div>

    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Código</th>
                <th>Nombres</th>
                <th>Apellidos</th>
                <th>Teléfono</th>
                <th>Correo</th>
                <th>Dirección</th>
                <th>F. Registro</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.IdCliente</td>
                    <td>@item.Nombres</td>
                    <td>@item.Apellidos</td>
                    <td>@item.Telefono</td>
                    <td>@item.Correo</td>
                    <td>@item.Direccion</td>
                    <td>@item.FechaRegistro.ToString("dd/MM/yyyy")</td>
                    <td class="text-center">
                        <a href="@Url.Action("Edit", "Cliente", new { id = item.IdCliente })" class="btn btn-warning btn-sm">
                            <i class="glyphicon glyphicon-pencil"></i> Editar
                        </a>
                        <a href="@Url.Action("Delete", "Cliente", new { id = item.IdCliente })" class="btn btn-danger btn-sm">
                            <i class="glyphicon glyphicon-trash"></i> Eliminar
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>