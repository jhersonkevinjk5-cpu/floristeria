@{
    WebApplicationfloristeria.Models.Usuario usuario =
    (WebApplicationfloristeria.Models.Usuario)Session["usuario"];
}

<!DOCTYPE html>
<html>
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewBag.Title - Dashboard Florería Pétalos y Aromas </title>

    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
          rel="stylesheet">
    <link rel="icon" type="image/png" href="@Url.Content("~/Contenido/Multimedia/IMG/favicon.png")" />

    <style>

        :root {
            --primary: #ff4f87;
            --dark: #111827;
            --light: #f9fafb;
            --card: #ffffff;
            --shadow: 0 10px 25px rgba(0,0,0,.07);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins',sans-serif;
            background: #f6f8fb;
        }

        /* ===== MAIN LAYOUT ===== */

        .wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* ===== SIDEBAR ===== */

        .sidebar {
            width: 270px;
            background: linear-gradient(180deg,#ff4f87,#ff7ba5);
            padding: 30px;
            position: fixed;
            height: 100vh;
            box-shadow: 0 5px 30px rgba(0,0,0,.12);
        }

        .logo {
            color: white;
            font-size: 22px;
            font-weight: 700;
            margin-bottom: 40px;
        }

        .sidebar a {
            display: block;
            color: white;
            text-decoration: none;
            margin: 12px 0;
            padding: 14px;
            border-radius: 12px;
            transition: .3s;
            font-weight: 500;
        }

            .sidebar a:hover {
                background: rgba(255,255,255,.15);
                transform: translateX(5px);
            }

        /* ===== CONTENT ===== */

        .main {
            margin-left: 270px;
            width: 100%;
        }

        /* ===== TOPBAR ===== */

        .topbar {
            background: white;
            padding: 20px 35px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: var(--shadow);
        }

        .search-box {
            background: #f3f4f6;
            padding: 12px 20px;
            border-radius: 30px;
            width: 300px;
            border: none;
            outline: none;
        }

        .user-panel {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .user-avatar {
            background: var(--primary);
            color: white;
            width: 42px;
            height: 42px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* ===== CONTENT BODY ===== */

        .content {
            padding: 35px;
        }

        /* ===== STATS ===== */

        .stats {
            display: grid;
            grid-template-columns: repeat(3,1fr);
            gap: 25px;
            margin-bottom: 35px;
        }

        .card-stat {
            background: white;
            padding: 30px;
            border-radius: 18px;
            box-shadow: var(--shadow);
            transition: .3s;
        }

            .card-stat:hover {
                transform: translateY(-5px);
            }

            .card-stat h3 {
                color: gray;
                font-size: 15px;
            }

            .card-stat h2 {
                margin-top: 10px;
                color: #111827;
            }

        /* ===== MAIN CARD ===== */

        .main-card {
            background: white;
            padding: 30px;
            border-radius: 20px;
            box-shadow: var(--shadow);
        }

        /* ===== FOOTER ===== */

        .footer {
            margin-top: 30px;
            text-align: center;
            color: gray;
        }

        /* ===== BUTTON ===== */

        .logout {
            margin-top: 40px;
            background: #e63e74 !important;
        }
    </style>

</head>

<body>

    <div class="wrapper">

        <!-- SIDEBAR -->

        <div class="sidebar">

            <div class="logo">
                <img src="~/Contenido/Multimedia/IMG/logo.png" width="70" /> Pétalos y Aromas
            </div>

            <a href="@Url.Action("Index","Home")">
                <i class="fa-solid fa-chart-line"></i> Dashboard
            </a>

            <a href="@Url.Action("Index","Producto")">
                <i class="fa-solid fa-box"></i> Productos
            </a>

            <a href="@Url.Action("Index","Categoria")">
                <i class="fa-solid fa-tags"></i> Categorías
            </a>

            <a href="@Url.Action("Index","Cliente")">
                <i class="fa-solid fa-users"></i> Clientes
            </a>

            <a href="@Url.Action("Index","Pedido")">
                <i class="fa-solid fa-cart-shopping"></i> Pedidos
            </a>

            <a href="@Url.Action("ExportarPDF","Home")">
                <i class="fa-solid fa-file-pdf"></i> Reportes PDF
            </a>

            <a href="@Url.Action("Logout","Auth")" class="logout">
                <i class="fa-solid fa-right-from-bracket"></i> Cerrar sesión
            </a>

        </div>


        <!-- MAIN -->

        <div class="main">

            <!-- TOPBAR -->

            <div class="topbar">

                <input type="text"
                       class="search-box"
                       placeholder="Buscar productos...">

                <div class="user-panel">

                    <i class="fa-regular fa-bell fa-lg"></i>

                    <span>@usuario.Nombres </span>

                    <div class="user-avatar">
                        <i class="fa-solid fa-user"></i>
                    </div>

                </div>

            </div>


            <!-- CONTENT -->

            <div class="content">

                <!-- STATS -->

                @if (ViewBag.TotalClientes != null)
                {
                    <div class="stats">

                        <div class="card-stat">
                            <h3>Ventas del mes</h3>
                            <h2>S/ @String.Format("{0:N2}", ViewBag.VentasMes ?? 0)</h2>
                        </div>

                        <div class="card-stat">
                            <h3>Pedidos</h3>
                            <h2>@ViewBag.TotalPedidos</h2>
                        </div>

                        <div class="card-stat">
                            <h3>Clientes</h3>
                            <h2>@ViewBag.TotalClientes</h2>
                        </div>

                    </div>
                }

                <!-- BODY -->

                <div class="main-card">

                    @RenderBody()

                </div>

                <div class="footer">
                    © @DateTime.Now.Year Pétalos y Aromas
                </div>

            </div>

        </div>

    </div>
    @if (ViewBag.ErrorShake != null)
    {
        <script>
            window.onload = () => loginError();
        </script>
    }

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", false)

</body>
</html>