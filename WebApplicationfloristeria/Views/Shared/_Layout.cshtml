@{
    WebApplicationfloristeria.Models.Usuario usuario = (WebApplicationfloristeria.Models.Usuario)Session["usuario"];
 }

<!DOCTYPE html>
    <html>
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>@ViewBag.Title - Florería Rosas del Jardín</title>

        @Styles.Render("~/Content/css")
        @Scripts.Render("~/bundles/modernizr")

        <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

        <style>
            body {
                font-family: 'Poppins', sans-serif;
                background: #fdfaf8;
                color: #333;
                min-height: 100vh;
                display: flex;
                flex-direction: column;
            }

            /* NAVBAR */
            .navbar-floreria {
                background: linear-gradient(135deg, #ff7aa2, #ff9eb5);
                box-shadow: 0 4px 20px rgba(0,0,0,.12);
                padding: 15px 0;
            }

            .navbar-brand {
                font-size: 1.6rem;
                font-weight: 700;
                color: white !important;
                letter-spacing: 1px;
            }

            .nav-link {
                color: white !important;
                font-weight: 500;
                margin: 0 10px;
                transition: .3s;
            }

                .nav-link:hover {
                    transform: translateY(-2px);
                    color: #fff8dc !important;
                }

            /* CONTENIDO */
            .body-content {
                flex: 1;
                margin-top: 35px;
                margin-bottom: 40px;
            }

            /* TARJETAS */
            .card-custom {
                background: white;
                border-radius: 18px;
                box-shadow: 0 10px 30px rgba(0,0,0,.08);
                padding: 25px;
            }

            /* BOTONES */
            .btn-pink {
                background: #ff5c8a;
                border: none;
                color: white;
                border-radius: 30px;
                padding: 10px 25px;
                font-weight: 600;
                transition: .3s;
            }

                .btn-pink:hover {
                    background: #e54877;
                    transform: translateY(-2px);
                }

            .btn-logout {
                border-radius: 25px;
                padding: 8px 20px;
                font-weight: 600;
            }

            /* USUARIO */
            .user-badge {
                color: white;
                margin-right: 15px;
                font-weight: 500;
            }

            /* FOOTER */
            footer {
                background: #2f3542;
                color: white;
                padding: 30px 0;
                margin-top: auto;
            }

            .footer-title {
                font-size: 1.2rem;
                font-weight: 600;
                margin-bottom: 10px;
            }

            .footer-copy {
                text-align: center;
                margin-top: 20px;
                opacity: .8;
            }

            /* TITULOS */
            h1, h2, h3 {
                color: #d63384;
                font-weight: 700;
            }
        </style>

    </head>

    <body>

        <nav class="navbar navbar-expand-lg navbar-floreria">
            <div class="container">

                @Html.ActionLink("🌸 Florería Rosas del Jardín", "Index", "Home", null,
                    new { @class = "navbar-brand" })

                <button class="navbar-toggler bg-light"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#menu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="menu">

                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            @Html.ActionLink("Inicio", "Index", "Home", null,
                                new { @class = "nav-link" })
                        </li>

                        <li class="nav-item">
                            @Html.ActionLink("Productos", "Index", "Producto", null,
                                new { @class = "nav-link" })
                        </li>

                        <li class="nav-item">
                            @Html.ActionLink("Categorías", "Index", "Categoria", null,
                                new { @class = "nav-link" })
                        </li>

                        <li class="nav-item">
                            @Html.ActionLink("Clientes", "Index", "Cliente", null,
                                new { @class = "nav-link" })
                        </li>

                        <li class="nav-item">
                            @Html.ActionLink("Pedidos", "Index", "Pedido", null,
                                new { @class = "nav-link" })
                        </li>

                    </ul>

                    @if (Session["usuario"] != null)
                    {
                        

                        <span class="user-badge">
                            👋 Bienvenido, @usuario.Nombres
                        </span>

                        <a href="@Url.Action("Logout","Auth")"
                           class="btn btn-danger btn-logout">
                            Cerrar sesión
                        </a>
                    }

                </div>
            </div>
        </nav>

        @RenderBody()
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
        @if (ViewBag.Ok != null){
            <script type="text/javascript">
                Swal.fire({
                    title: "@ViewBag.Titulo",
                    text: "@ViewBag.Mensaje",
                    icon: "@(ViewBag.Ok ? "succes" : "error")"

                });
            </script>
        }
        @RenderSection("AlertaEliminar", false)
        @RenderSection("JSNavegador", false)

        <footer>
            <div class="container">

                <div class="row">

                    <div class="col-md-4">
                        <div class="footer-title">🌸 Florería</div>
                        <p>
                            Ramos, arreglos florales y detalles especiales
                            para toda ocasión.
                        </p>
                    </div>

                    <div class="col-md-4">
                        <div class="footer-title">📍 Contacto</div>
                        <p>
                            Lima, Perú<br />
                            +51 999 999 999<br />
                            ventas@floreria.com
                        </p>
                    </div>

                    <div class="col-md-4">
                        <div class="footer-title">🌐 Redes Sociales</div>
                        <p>
                            Facebook<br />
                            Instagram<br />
                            WhatsApp
                        </p>
                    </div>

                </div>

                <hr />

                <div class="footer-copy">
                    © @DateTime.Now.Year - Florería Rosas del Jardín.
                    Todos los derechos reservados.
                </div>

            </div>
        </footer>

        @Scripts.Render("~/bundles/jquery")
        @Scripts.Render("~/bundles/bootstrap")
        @RenderSection("scripts", required: false)


    </body>
</html>
