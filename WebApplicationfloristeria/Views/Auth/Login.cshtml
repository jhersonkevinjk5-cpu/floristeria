@{
    ViewBag.Title = "Iniciar Sesión";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Login - Florería</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background: #f5f5f5;
        }

        .login-container {
            max-width: 400px;
            margin: 100px auto;
        }

        .card {
            border-radius: 15px;
            box-shadow: 0px 4px 10px rgba(0,0,0,.15);
        }

        .card-header {
            text-align: center;
            background: #198754;
            color: white;
            font-size: 24px;
            font-weight: bold;
        }

        .btn-login {
            width: 100%;
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="login-container">
            <div class="card">

                <div class="card-header">
                    🌹 Florería MVC
                </div>

                <div class="card-body">

                    @if (ViewBag.Mensaje != null)
                    {
                        <div class="alert alert-danger">
                            @ViewBag.Mensaje
                        </div>
                    }

                    @using (Html.BeginForm("Login", "Auth", FormMethod.Post))
                    {
                        <div class="mb-3">
                            <label class="form-label">
                                Correo
                            </label>

                            <input type="email"
                                   name="usuarioNombre"
                                   class="form-control"
                                   required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">
                                Contraseña
                            </label>

                            <input type="password"
                                   name="contraseña"
                                   class="form-control"
                                   required />
                        </div>

                        <button type="submit"
                                class="btn btn-success btn-login">
                            Ingresar
                        </button>
                    }

                </div>

            </div>
        </div>
    </div>

</body>
</html>