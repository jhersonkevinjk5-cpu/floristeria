@{
    ViewBag.Title = "Iniciar Sesión";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Iniciar Sesión - Florería | Pétalos y Aromas</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <link rel="icon" type="image/png" href="@Url.Content("~/Contenido/Multimedia/IMG/favicon.png")" />
    <link href="~/Contenido/CSS/login.css" rel="stylesheet" />
    <script src="~/Contenido/JS/login.js">

    </script>
</head>
<body>

    <script type="module"
            src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.3.0/model-viewer.min.js">
    </script>
    <video autoplay muted loop id="bg-video">
        <source src="@Url.Content("~/Contenido/Multimedia/Video/fondo.mp4")" type="video/mp4">
    </video>
    <div class="overlay"></div>

    <!-- partículas -->
    <div class="particle" style="width:8px;height:8px;left:10%;animation-duration:12s;"></div>
    <div class="particle" style="width:12px;height:12px;left:25%;animation-duration:15s;"></div>
    <div class="particle" style="width:10px;height:10px;left:50%;animation-duration:10s;"></div>
    <div class="particle" style="width:14px;height:14px;left:70%;animation-duration:17s;"></div>
    <div class="particle" style="width:9px;height:9px;left:85%;animation-duration:13s;"></div>

    <!-- pétalos -->
    <div class="petal" style="left:15%; animation-duration:18s;">🍃</div>
    <div class="petal" style="left:35%; animation-duration:14s;">🍃</div>
    <div class="petal" style="left:60%; animation-duration:20s;">🍃</div>
    <div class="petal" style="left:80%; animation-duration:16s;">🍃</div>

    <div class="container-fluid main-container">
        <div class="row h-100">

            <!-- Modelo -->
            <div class="col-md-7 model-section">

                <div class="glow"></div>

                <model-viewer src="@Url.Content("~/Contenido/Models3D/flor.glb")"
                              camera-controls
                              disable-zoom
                              disable-tap
                              auto-rotate>
                </model-viewer>

            </div>

            <!-- Login -->
            <!-- Login -->
            <div class="col-md-5 login-section">

                <div class="login-card">

                    <div class="login-header">
                        <div class="logo"><img src="~/Contenido/Multimedia/IMG/logo.png" width="70"/> Pétalos y Aromas Florería</div>
                        <div class="subtitle">Sistema de gestión floral inteligente</div>
                    </div>

                    @if (ViewBag.Mensaje != null)
                    {
                        <div class="alert alert-danger custom-alert">
                            @ViewBag.Mensaje
                        </div>
                    }

                    @using (Html.BeginForm("Login", "Auth", FormMethod.Post))
                    {
                        <div class="login-container">

                            <div class="login-card-flip" id="card">

                                <!-- FRONT -->
                                <div class="face front">
                                    <h3>👤 Acceso Usuario</h3>

                                    <div class="input-group">
                                        <input type="email" name="correoUsuario" class="form-control" placeholder="Correo electrónico" />
                                    </div>

                                    <div class="input-group">
                                        <input type="password" name="clave" class="form-control" placeholder="Contraseña" />
                                    </div>

                                    <input type="hidden" id="tipoLogin" name="tipoLogin" value="usuario" />
                                </div>

                                <!-- BACK -->
                                <div class="face back">
                                    <h3>🧑‍🤝‍🧑 Acceso Cliente</h3>

                                    <div class="input-group">
                                        <input type="text" name="nombreCliente" class="form-control" placeholder="Nombre completo" />
                                    </div>

                                    <div class="input-group">
                                        <input type="email" name="correoCliente" class="form-control" placeholder="Correo electrónico" />
                                    </div>

                                </div>

                            </div>
                            <br />
                            <button type="submit" class="btn btn-login">
                                Entrar al sistema ✨
                            </button>

                            <button type="button" class="btn btn-switch" onclick="flipCard()">
                                Cambiar modo
                            </button>

                        </div>
                    }
                </div>
            </div>




        </div>
    </div>

</body>
</html>