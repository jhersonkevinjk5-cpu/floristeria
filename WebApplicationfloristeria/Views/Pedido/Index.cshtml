@model IEnumerable<WebApplicationfloristeria.Models.Pedido>

@{
    ViewBag.Title = "Listado de Pedidos";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Historial de Pedidos</h2>
        <a href="@Url.Action("Create", "Pedido")" class="btn btn-primary">
            <i class="glyphicon glyphicon-shopping-cart"></i> Nuevo Pedido
        </a>
    </div>

    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>N° Pedido</th>
                <th>Fecha</th>
                <th>Cliente</th>
                <th>Dirección Entrega</th>
                <th>Sub Total</th>
                <th>IGV (18%)</th>
                <th>Total</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.IdPedido</td>
                    <td>@item.FechaPedido.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@(item.Cliente != null ? item.Cliente.Nombres + " " + item.Cliente.Apellidos : "No asignado")</td>
                    <td>@item.DireccionEntrega</td>
                    <td>S/. @item.SubTotal.ToString("F2")</td>
                    <td>S/. @item.IGV.ToString("F2")</td>
                    <td><strong>S/. @item.Total.ToString("F2")</strong></td>
                </tr>
            }
        </tbody>
    </table>
</div>